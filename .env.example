PORT=4000
WEBHOOK_SECRET=replace-with-local-secret

# Force local mock values when SAP is unavailable or should not be called.
SAP_ODATA_FORCE_MOCK=true

# Local BAS/UI5 proxy, Destination, or direct SAP OData base URL.
SAP_ODATA_BASE_URL=http://localhost:8080
SAP_ODATA_CONTRACT_PATH=/sap/opu/odata/sap/ZCLM_CONTRACT_SRV_SRV/contractSet

# Supported lookup modes: shortKey, filter, pathOnly.
SAP_ODATA_LOOKUP_MODE=shortKey

# Supported response formats: json, xml.
SAP_ODATA_RESPONSE_FORMAT=xml
SAP_CLIENT=000

# Never commit real credentials. Prefer secure local env/config mechanisms.
SAP_ODATA_USERNAME=your-sap-user
SAP_ODATA_PASSWORD=your-sap-password
